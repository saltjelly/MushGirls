<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- 여기서부터 시작 -->
	<AlienRace.ThingDef_AlienRace ParentName="Human">

		<defName>Porian</defName>
		<label>포리안</label>
		<description>버섯을 연상시키는 미소녀 외계 종족. 습하고 어두운 환경을 좋아한다.</description>

		<race>
			<baseBodySize>0.95</baseBodySize>
			<baseHealthScale>1.05</baseHealthScale>
			<lifeExpectancy>85</lifeExpectancy>
		</race>

		<alienRace>
			<generalSettings>
				<allowHumanBios>true</allowHumanBios>
				<corpseCategory>CorpsesHumanlike</corpseCategory>

				<alienPartGenerator>
					<bodyAddons>
						<!-- 버섯갓 부분 -->
						<li>
							<name>MushroomCap</name>
							<conditions>
								<Gene>Porian_MushroomCap</Gene>
							</conditions>
							<path>Things/Addons/MushroomCap</path>
							<drawSize>(1.0,1.0)</drawSize>
							<offsets>
								<north>
									<offset>(0,0.55)</offset>
								</north>
								<south>
									<offset>(0,0.55)</offset>
								</south>
								<east>
									<offset>(0,0.55)</offset>
								</east>
							</offsets>
						</li>
					</bodyAddons>
				</alienPartGenerator>
			</generalSettings>
		</alienRace>

		<!-- ✅ HediffGivers는 여기 (AlienRace.ThingDef_AlienRace 직속) -->
		<hediffGivers>
			<li Class="HediffGiver_Constant">
				<hediff>Porian_Regeneration</hediff>
				<severity>0.5</severity>
			</li>
		</hediffGivers>

	</AlienRace.ThingDef_AlienRace>

</Defs>