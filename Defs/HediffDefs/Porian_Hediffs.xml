<?xml version="1.0" encoding="utf-8"?>
<Defs>


	<HediffDef>
		<defName>Porian_FungalBoost</defName>
		<label>fungal stride</label>
		<description>Fungal gravel 위에서 빠르게 움직이는 버섯 적응 효과.</description>
		<defaultLabelColor>(0.4, 0.85, 0.35)</defaultLabelColor>
		<isBad>false</isBad>

		<stages>
			<li>
		<label>균사 질주</label>

		<statOffsets>
			<MoveSpeed>0.30</MoveSpeed>
		</statOffsets>
			</li>
		</stages>

	</HediffDef>
	
	<HediffDef>
		<defName>Porian_Regeneration</defName>
		<label>포리안 재생력</label>
		<description>포리안의 강력한 균사 재생 능력으로 흉터가 서서히 사라진다.</description>

		<hediffClass>HediffWithComps</hediffClass>

		<!-- ✅ 여기 수정 -->
		<initialSeverity>0.5</initialSeverity>
		<!-- <defaultSeverity>0.5</defaultSeverity>  ← 이 줄 삭제 -->

		<maxSeverity>1.0</maxSeverity>

		<comps>
			<!-- 지속성 유지 -->
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>0.0001</severityPerDay>
			</li>

			<!-- 재생 컴포넌트 -->
			<li Class="Porian.HediffCompProperties_Regeneration">
				<healIntervalDays>15</healIntervalDays>
				<healIntervalDaysMax>30</healIntervalDaysMax>
				<healScarOnly>true</healScarOnly>
			</li>
		</comps>

		<stages>
			<li>
				<label>균사생장</label>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.05</offset>
					</li>
				</capMods>
			</li>
		</stages>
	</HediffDef>

</Defs>